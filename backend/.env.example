# RetailMind Environment Configuration

# Application Settings
APP_NAME=RetailMind
DEBUG=true

# Database Configuration
# For local development
DATABASE_URL=postgresql://retailmind:password@localhost:5432/retailmind

# For AWS RDS (production)
# DATABASE_URL=postgresql://username:password@retailmind-db.cluster-xyz.us-east-1.rds.amazonaws.com:5432/retailmind

# Redis Configuration  
# For local development
REDIS_URL=redis://localhost:6379/0

# For AWS ElastiCache (production)
# REDIS_URL=redis://retailmind-cache.xyz.cache.amazonaws.com:6379/0

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ML Model Configuration
MODEL_CACHE_TTL=3600
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# AWS Configuration (for future Bedrock integration)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Business Logic Configuration
STOCKOUT_RISK_DAYS=7
EXPIRY_WARNING_DAYS=3
SAFETY_STOCK_MULTIPLIER=1.2